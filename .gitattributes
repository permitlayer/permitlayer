# Enforce LF line endings on Windows checkout for text files. Without
# this, Windows' default `core.autocrlf=true` writes CRLF into the
# working tree, which breaks tests that match source content with
# literal `\n` separators (xtask::validate_plugin_api::tests is the
# original offender — see Story 7.7 closeout).

* text=auto eol=lf

# Specifically pin source files to LF — belt-and-braces for runners
# that override the workspace `text=auto` heuristic.
*.rs    text eol=lf
*.toml  text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.json  text eol=lf
*.sh    text eol=lf

# Windows-native scripts keep CRLF so they execute correctly under
# PowerShell / cmd.exe.
*.ps1   text eol=crlf
*.bat   text eol=crlf
*.cmd   text eol=crlf

# Binary blobs untouched.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.zip   binary
*.tar   binary
*.gz    binary
*.bz2   binary
*.xz    binary
*.pdf   binary
*.p12   binary
*.pfx   binary
